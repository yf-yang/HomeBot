# HomeBot API 密钥配置模板
# 复制此文件为 .env.local 并填入你的实际密钥

# ============================================
# 火山引擎 TTS 配置
# ============================================
# 火山引擎应用ID，从 https://console.volcengine.com/speech/service 获取
VOLCANO_APPID=your_volcano_appid_here

# 火山引擎访问令牌
VOLCANO_ACCESS_TOKEN=your_volcano_access_token_here

# TTS 资源ID（可选，默认使用 seed-tts-2.0）
# VOLCANO_RESOURCE_ID=seed-tts-2.0

# TTS 音色类型（可选，默认使用 zh_female_vv_uranus_bigtts）
# VOLCANO_VOICE_TYPE=zh_female_vv_uranus_bigtts

# ============================================
# 火山Ark LLM 配置
# ============================================
# 火山方舟 API Key，从 https://console.volcengine.com/ark/ 获取
ARK_API_KEY=your_ark_api_key_here

# 模型ID（必填）
# 从火山方舟控制台创建推理接入点后获取，格式如 ep-20250324123456-abcdef
ARK_MODEL_ID=ep-your_model_id_here

# API 基础地址（可选，默认使用火山Ark地址）
# ARK_API_URL=https://ark.cn-beijing.volces.com/api/v3

# ============================================
# 兼容：DeepSeek LLM 配置（如仍需使用DeepSeek）
# ============================================
# DeepSeek API Key，从 https://platform.deepseek.com/api_keys 获取
# DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# API 基础地址（可选，默认使用官方地址）
# DEEPSEEK_API_URL=https://api.deepseek.com/v1

# 模型名称（可选，默认使用 deepseek-chat）
# DEEPSEEK_MODEL=deepseek-chat

# ============================================
# 图片理解/Vision API 配置
# ============================================
# 根据你使用的图片理解服务选择对应的配置

# 选项1: 使用 DeepSeek-VL (与LLM共用key)
# VISION_PROVIDER=deepseek
# VISION_API_KEY=sk-your_deepseek_api_key_here
# VISION_API_URL=https://api.deepseek.com/v1

# 选项2: 使用阿里云百炼/通义千问VL
# VISION_PROVIDER=qwen
# VISION_API_KEY=your_qwen_api_key_here
# VISION_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 选项3: 使用 OpenAI GPT-4V
# VISION_PROVIDER=openai
# VISION_API_KEY=sk-your_openai_api_key_here
# VISION_API_URL=https://api.openai.com/v1

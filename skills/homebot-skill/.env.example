# HomeBot 机器人连接配置
# 复制此文件为 .env 并填写实际值，或设置对应的环境变量

# === 机器人连接配置（必填）===
# 机器人 IP 地址，根据你的实际网络配置修改
HOMEBOT_IP=192.168.1.13

# ZeroMQ 端口配置（通常使用默认值即可）
HOMEBOT_CHASSIS_PORT=5556
HOMEBOT_ARM_PORT=5557
HOMEBOT_VIDEO_PORT=5560

# 图像捕获超时时间（秒）
HOMEBOT_CAPTURE_TIMEOUT=10.0

# 图像保存目录
HOMEBOT_OUTPUT_DIR=.

# === 火山引擎视觉分析配置（可选）===
# 如需使用视觉分析功能，请填写以下配置
# 从火山引擎控制台获取: https://console.volcengine.com/
ARK_API_KEY=your-api-key-here

# 模型 ID（可选，使用默认值即可）
ARK_MODEL_ID=doubao-seed-2-0-lite-260215
